<?xml version="1.0" encoding="UTF-8"?>
<?eclipse version="3.4"?>
<plugin>
   <!-- Auto-start the MCP HTTP server once the workbench is ready. -->
   <extension point="org.eclipse.ui.startup">
      <startup class="nhb.eclipse.ultimate.mcpserver.StartupHook"/>
   </extension>

   <extension point="org.eclipse.ui.preferencePages">
      <page id="nhb.eclipse.ultimate.mcpserver.preferencePage" name="Eclipse Ultimate MCP Server"
            class="nhb.eclipse.ultimate.mcpserver.ui.McpPreferencePage"/>
   </extension>

   <extension point="org.eclipse.ui.commands">
      <category id="nhb.eclipse.ultimate.mcpserver.commandCategory" name="Eclipse Ultimate MCP"/>
      <command id="nhb.eclipse.ultimate.mcpserver.commands.startServer" name="Start MCP Server"
            categoryId="nhb.eclipse.ultimate.mcpserver.commandCategory"/>
      <command id="nhb.eclipse.ultimate.mcpserver.commands.stopServer" name="Stop MCP Server"
            categoryId="nhb.eclipse.ultimate.mcpserver.commandCategory"/>
      <command id="nhb.eclipse.ultimate.mcpserver.commands.restartServer" name="Restart MCP Server"
            categoryId="nhb.eclipse.ultimate.mcpserver.commandCategory"/>
      <command id="nhb.eclipse.ultimate.mcpserver.commands.openPreferences" name="MCP Server Settings..."
            categoryId="nhb.eclipse.ultimate.mcpserver.commandCategory"/>
      <command id="nhb.eclipse.ultimate.mcpserver.commands.showConnections" name="MCP Server Connections..."
            categoryId="nhb.eclipse.ultimate.mcpserver.commandCategory"/>
   </extension>

   <extension point="org.eclipse.ui.handlers">
      <handler commandId="nhb.eclipse.ultimate.mcpserver.commands.startServer"
            class="nhb.eclipse.ultimate.mcpserver.ui.StartServerHandler"/>
      <handler commandId="nhb.eclipse.ultimate.mcpserver.commands.stopServer"
            class="nhb.eclipse.ultimate.mcpserver.ui.StopServerHandler"/>
      <handler commandId="nhb.eclipse.ultimate.mcpserver.commands.restartServer"
            class="nhb.eclipse.ultimate.mcpserver.ui.RestartServerHandler"/>
      <handler commandId="nhb.eclipse.ultimate.mcpserver.commands.openPreferences"
            class="nhb.eclipse.ultimate.mcpserver.ui.OpenPreferencesHandler"/>
      <handler commandId="nhb.eclipse.ultimate.mcpserver.commands.showConnections"
            class="nhb.eclipse.ultimate.mcpserver.ui.ShowConnectionsHandler"/>
   </extension>
</plugin>
